-- CREATION DE LA TABLE CLIENTS
CREATE TABLE Clients(
ClientID INT PRIMARY KEY NOT NULL,
Nom VARCHAR (50) NOT NULL,
Prenom VARCHAR (50) NOT NULL,
Email VARCHAR (255) NOT NULL
);
-- CREATION DE LA TABLE FOURNISSEUR
CREATE TABLE Fournisseurs(
FournisseurID INT PRIMARY KEY NOT NULL,
NomFournisseur VARCHAR (50) NOT NULL,
Email VARCHAR (50) NOT NULL
); 

-- CREATION DE LA TABLE PRODUITS
CREATE TABLE Produits (
ProduitID INT PRIMARY KEY NOT NULL,
NomProduit VARCHAR (100) NOT NULL,
Categorie VARCHAR (100) NOT NULL,
PrixUnitraire DECIMAL(10,2) NOT NULL,
FournisseurID INT NOT NULL,
FOREIGN KEY (FournisseurID) REFERENCES Fournisseurs(FournisseurID)
);

-- CREATION DE LA TABLE EMPLOYES

CREATE TABLE Employes(
EmployeID INT PRIMARY KEY NOT NULL,
NomEmployee VARCHAR (50) NOT NULL,
Prenom VARCHAR (50) NOT NULL,
Email VARCHAR (255) NOT NULL
);
-- CREATION DE LA TABLE VENTES
CREATE TABLE Ventes(
VenteID INT PRIMARY KEY NOT NULL,
DateVente Date NOT NULL,
Montant Decimal (10,2) NOT NULL,
ClientID INT NOT NULL,
ProduitID INT NOT NULL,
EmployeID INT NOT NULL,
Foreign key (ClientID) REFERENCES Clients (ClientID),
Foreign key (ProduitID) REFERENCES Produits (ProduitID),
Foreign key (EmployeID) REFERENCES Employes (EmployeID)
);

-- 2 METHODES POUR SUPPRIMER DES DOUBLON SUR QUELQUES COLONNES
-- VRAI DOUBLON : Enregistrement Double d'un même élément ; ID Différent
-- FAUX DOUBLON : Elements différents similitude sur certaines colonnes,

-- ROW_NUMBER () 
--SELECT * FROM (SELECT Columns, ROW_NUMBER() OVER (PARTITION BY Columns ORDER BY ColumnID) AS RW
FROM Table) R 
WHERE R.RW > 1 ;

SELECT * FROM (SELECT Nom, Prenom, Email, ROW_NUMBER() OVER (PARTITION BY Nom, Prenom, Email ORDER BY ClientID) AS RW
FROM Clients) R 
WHERE R.RW > 1 ;

-- COUNT()
-- SELECT Columns, COUNT(ColumnID)
FROM Table
GROUP BY Columns
HAVING COUNT(ColumnID))> 1;

SELECT Nom, Prenom, Email, COUNT(ClientID)
FROM Clients
GROUP BY Nom, Prenom, Email
HAVING COUNT(ClientID)> 1;
